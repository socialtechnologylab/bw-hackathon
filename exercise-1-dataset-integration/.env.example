# Workshop endpoint — already filled in for you.
BW_ENDPOINT_URL=https://bw.stl.dev

# Team credentials — paste from the card you were handed.
# BW_TEAM_ID is the short human-readable team name (e.g. "team-demo").
# BW_TEAM_TOKEN is the long opaque secret (e.g. "bw-demo-token-please-change").
# /exercise-1/submit reads BW_TEAM_TOKEN only. BW_TEAM_ID is here for
# parity with Exercise 2, which uses both.
BW_TEAM_ID=
BW_TEAM_TOKEN=
